# Database — local Docker default; swap to Railway pooled URL in prod.
DATABASE_URL=postgresql://jesusfilm_rag:jesusfilm_rag_dev@localhost:5434/jesusfilm_rag

# OpenRouter — embedding provider. Replace the key before any shared use.
# Default embedding model: qwen/qwen3-embedding-8b at 1536 dims (ADR-0005).
# Provider: https://openrouter.ai/qwen/qwen3-embedding-8b
# Query-side instruction (documents embed raw) — recommended for qwen:
# EMBED_QUERY_INSTRUCTION="Given a web search query, retrieve relevant passages that answer the query"
EMBED_MODEL_ID=qwen/qwen3-embedding-8b
OPENROUTER_API_KEY=replace-me-sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Per-batch embed attempts (1 initial try + retries) before an index run aborts.
# Backoff is incremental: 500ms → 1s → 2s → 4s → 8s → 8s … (capped at 8s). Default
# 10 (~47s of retry per batch) so a transient OpenRouter blip recovers instead of
# aborting a multi-hour ingest — see docs/ops/prod-ingest.md and issue #64.
# EMBED_MAX_ATTEMPTS=10

# --- Multilingual embedder (Qwen3-Embedding-8B) — see EVAL-INBOX.md / #39 P1 ---
# To evaluate/serve the multilingual model, override the three lines below.
# Qwen is MRL-native (4096→1536) and instruction-aware; OpenRouter honours the
# `dimensions` param so client-side truncation stays off there.
#   EMBED_MODEL_ID=qwen/qwen3-embedding-8b
#   EMBED_QUERY_INSTRUCTION=Given a web search query, retrieve relevant passages that answer the query
# For a self-hosted vLLM endpoint that returns native 4096-d instead of 1536:
#   EMBED_BASE_URL=http://localhost:8000/v1
#   EMBED_TRUNCATE_DIMENSIONS=true

# Language sweep (scripts/language-sweep.ts, issue #73) — where per-run logs land
# (report/changelog/csv/ledger). Local logs only, never committed. Overridden by
# the --out-dir flag; defaults to <cwd>/reports when unset. See docs/ops/language-sweep.md.
# LANGUAGE_SWEEP_OUT_DIR=/absolute/path/to/sweep-logs

# Serving — the /v1 HTTP adapter (pnpm serve).
# PORT is injected by Railway in prod; defaults to 8080 locally.
PORT=8080
# Bearer token → the source keys it may see. JSON map; ["*"] = all sources.
# Issued one per consumer, rotated per consumer. Required by `pnpm serve`.
# Matches the dev token baked into docker-compose.yml so the README curls work
# against either the host (`pnpm serve`) or the container. Replace for real use.
SERVE_BEARER_TOKENS={"local-dev-token":["*"]}

# Firecrawl — the rendered-fetch transport for WALLED sources (ADR-0012), i.e.
# a source whose registry crawl policy declares `fetchStrategy: "firecrawl"`.
# Conditional: acquiring such a source fails loudly at wiring time without it;
# plain-HTTP acquire, ingest, query, serve, and CI never read it. Local dev uses
# the free-tier key; production resolves the hobby-tier key via docker secret
# pull, never from this file. Billed per scraped page — see docs/ops/prod-ingest.md.
# FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx