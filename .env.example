# Database — local Docker default; swap to Railway pooled URL in prod.
DATABASE_URL=postgresql://jesusfilm_rag:jesusfilm_rag_dev@localhost:5434/jesusfilm_rag

# OpenRouter — embedding provider. Replace the key before any shared use.
# Default embedding model: openai/text-embedding-3-small at 1536 dims.
# Provider: https://openrouter.ai/openai/text-embedding-3-small
OPENROUTER_API_KEY=replace-me-sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBED_MODEL_ID=openai/text-embedding-3-small

# MCP server
MCP_PORT=3333
MCP_BEARER_TOKEN=local-dev-token-replace-me
# Comma-separated tag list defining this consumer's scope. Tag values use the
# namespace:value form documented in README.md. Empty/missing = no access.
MCP_BEARER_SCOPES=audience:public,lang:en,media:text

# Secrets — generate with: openssl rand -hex 32
# Throwaway dev values — replace before any shared use.
CLIENT_HASH_SECRET=4501bfb8c11c077b7ad2f43c07cfd3ad8aea927ebacd54674d89e40d0e81d323
ADMIN_PASSWORD=06d02445622ad0282d9c8d15bd6c5d5049f813c44c281e546153fd06ed6700cf
