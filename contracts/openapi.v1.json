{
  "openapi": "3.0.3",
  "info": {
    "title": "JesusFilm RAG — Retrieval API",
    "version": "1.0.0",
    "description": "Read-only retrieval over a curated, cited corpus. The canonical shape consumers map onto; the engine does not bend. Versioning: additive change = same major; breaking change = a new /v2 beside /v1."
  },
  "paths": {
    "/v1/health": {
      "get": {
        "summary": "Liveness probe (unauthenticated).",
        "responses": {
          "200": {
            "description": "Service is up.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    }
                  },
                  "required": [
                    "status"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/search": {
      "post": {
        "summary": "Retrieve ranked, cited results for a query.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ranked results (possibly empty).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed JSON or request failing the contract.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or unknown bearer token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal error — e.g. a retrieval or embedding-provider failure.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "RetrievalPolicy": {
        "type": "object",
        "properties": {
          "allowedSourceKeys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preferSourceKey": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "topK": {
            "type": "integer",
            "exclusiveMinimum": true,
            "minimum": 0,
            "maximum": 50
          },
          "minScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      },
      "RankedResult": {
        "type": "object",
        "properties": {
          "chunkId": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "text": {
            "type": "string"
          },
          "ord": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "citation": {
            "$ref": "#/components/schemas/Citation"
          }
        },
        "required": [
          "chunkId",
          "score",
          "text",
          "ord",
          "tags",
          "citation"
        ],
        "additionalProperties": false
      },
      "Citation": {
        "type": "object",
        "properties": {
          "sourceKey": {
            "type": "string"
          },
          "sourceName": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "sourceKey",
          "sourceName",
          "title",
          "url"
        ],
        "additionalProperties": false
      },
      "SearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "policy": {
            "$ref": "#/components/schemas/RetrievalPolicy"
          }
        },
        "required": [
          "query"
        ],
        "additionalProperties": false
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RankedResult"
            }
          }
        },
        "required": [
          "results"
        ],
        "additionalProperties": false
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "issues": {
            "type": "array"
          }
        },
        "required": [
          "error"
        ]
      }
    }
  }
}
