{
  "name": "jesusfilm-rag",
  "version": "0.0.1",
  "private": true,
  "description": "Retrieval system serving biblically aligned content to JFP systems via MCP. Read-only retrieval over a curated corpus.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "acquire": "tsx scripts/acquire.ts",
    "acquire:production": "tsx scripts/acquire-production.ts",
    "index": "tsx scripts/index.ts",
    "index:production": "tsx scripts/index-production.ts",
    "query": "tsx scripts/query.ts",
    "retrieve:production": "tsx scripts/retrieve-production.ts",
    "serve": "tsx scripts/serve.ts",
    "smoke": "tsx scripts/smoke.ts",
    "gen:contract": "tsx scripts/gen-contract.ts",
    "eval": "tsx scripts/eval.ts",
    "eval:production": "tsx scripts/eval-production.ts",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "node-html-parser": "^7.1.0",
    "postgres": "^3.4.9",
    "yaml": "^2.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.0.0",
    "dependency-cruiser": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^4.1.5",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=20.12"
  },
  "packageManager": "pnpm@9.15.0"
}
